{
  "info": {
    "_postman_id": "7a3b4e6d-9b5a-4b2c-8cb3-1049c30f7888",
    "name": "Custom Certificate Templates and Patient Certificates APIs",
    "description": "Postman Collection for newly added features including Doctor customizable certificate templates and final patient generated certificates.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Doctor Certificate Templates",
      "item": [
        {
          "name": "Get All Doctor Templates (Customized or Defaults)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/doctors/1/certificate-templates",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "doctors",
                "1",
                "certificate-templates"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Specific Doctor Template By Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/doctors/1/certificate-templates/maladie",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "doctors",
                "1",
                "certificate-templates",
                "maladie"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Upsert Custom Doctor Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"certificateType\": \"maladie\",\n  \"title\": \"Arrêt de maladie personnalisé\",\n  \"templateText\": \"Je soussigné, Dr. {{doctorName}}, accorde un repos médical à {{patientName}} pour {{daysCount}} jours.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doctors/1/certificate-templates",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "doctors",
                "1",
                "certificate-templates"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Patient Certificates",
      "item": [
        {
          "name": "Save Generated Patient Certificate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorID\": 1,\n  \"certificateType\": \"maladie\",\n  \"title\": \"Certificat d'arrêt de travail personnalisé\",\n  \"text\": \"Je soussigné, Dr. Gregory House, accorde un repos médical à John Doe pour 5 jours.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patient/1/certificates",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "patient",
                "1",
                "certificates"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Certificates For A Patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patient/1/certificates",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "patient",
                "1",
                "certificates"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Specific Patient Certificate By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patient/certificates/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "patient",
                "certificates",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Patient Certificate",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Certificat d'arrêt de travail\",\n  \"text\": \"Je soussigné, Dr. Gregory House, certifie l'arrêt de travail prolongé à 10 jours.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patient/certificates/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "patient",
                "certificates",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Patient Certificate",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patient/certificates/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "patient",
                "certificates",
                "1"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
